# NanoPi K1 Plus Base Profile
# Stable boot, LuCI management, SSH, onboard Wi-Fi driver, USB HID/storage,
# common filesystems, and basic diagnostics.

CONFIG_TARGET_sunxi=y
CONFIG_TARGET_sunxi_cortexa53=y
CONFIG_TARGET_sunxi_cortexa53_DEVICE_friendlyarm_nanopi-k1-plus=y
CONFIG_TARGET_ROOTFS_PARTSIZE=512

# LuCI and management
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_ca-bundle=y

# Onboard Wi-Fi driver only. Wi-Fi AP stack is intentionally not selected.
CONFIG_PACKAGE_kmod-rtl8189es=y

# Storage and filesystems
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-hid=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_e2fsprogs=y

# Basic diagnostics
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_evtest=y
CONFIG_PACKAGE_libdrm-tests=y
