# NanoPi K1 Plus Full Profile
# Superset of Base Profile with router UI, AP stack, sharing, USB expansion,
# external USB Bluetooth preparation, hardware tools, and lightweight monitoring.

CONFIG_TARGET_sunxi=y
CONFIG_TARGET_sunxi_cortexa53=y
CONFIG_TARGET_sunxi_cortexa53_DEVICE_friendlyarm_nanopi-k1-plus=y
CONFIG_TARGET_ROOTFS_PARTSIZE=4096

# Base: LuCI and management
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_ca-bundle=y

# Full: LuCI additions
CONFIG_PACKAGE_luci-ssl-openssl=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-commands=y
CONFIG_PACKAGE_luci-app-filebrowser=y
CONFIG_PACKAGE_luci-app-diskman=y

# Onboard Wi-Fi is intentionally excluded for LAN-first recovery stability.

# Storage and filesystems
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-hid=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_dosfstools=y
CONFIG_PACKAGE_exfat-fsck=y
CONFIG_PACKAGE_exfat-mkfs=y
CONFIG_PACKAGE_parted=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_smartmontools=y
CONFIG_PACKAGE_hdparm=y

# Sharing and file transfer
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_wsdd2=y
CONFIG_PACKAGE_openssh-sftp-server=y

# USB serial adapters
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-ch341=y
CONFIG_PACKAGE_kmod-usb-serial-cp210x=y
CONFIG_PACKAGE_kmod-usb-serial-ftdi=y
CONFIG_PACKAGE_kmod-usb-serial-pl2303=y

# USB Ethernet adapters
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y
CONFIG_PACKAGE_kmod-usb-net-asix=y
CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=y

# External USB Bluetooth only. Onboard Bluetooth remains UNKNOWN.
CONFIG_PACKAGE_kmod-bluetooth=y
CONFIG_PACKAGE_kmod-btusb=y
CONFIG_PACKAGE_bluez-daemon=y
CONFIG_PACKAGE_bluez-utils=y
CONFIG_PACKAGE_bluez-utils-extra=y

# Hardware diagnostics
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_mmc-utils=y
CONFIG_PACKAGE_i2c-tools=y
CONFIG_PACKAGE_gpiod-tools=y
CONFIG_PACKAGE_evtest=y
CONFIG_PACKAGE_libdrm-tests=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_lsof=y
CONFIG_PACKAGE_strace=y

# Lightweight monitoring
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-cpufreq=y
CONFIG_PACKAGE_collectd-mod-thermal=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-load=y
CONFIG_PACKAGE_collectd-mod-interface=y
CONFIG_PACKAGE_collectd-mod-uptime=y
CONFIG_PACKAGE_luci-app-watchcat=y
CONFIG_PACKAGE_watchcat=y
